<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <include
        android:id="@+id/headerBackDetail"
        layout="@layout/header_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerBackDetail"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvBigImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:backgroundTint="@color/highlightcard"
                app:cardCornerRadius="0dp"
                app:cardPreventCornerOverlap="false"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivBigImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/sotl2">

                </ImageView>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvPoster"
                android:layout_width="200dp"
                android:layout_height="0dp"
                android:layout_marginEnd="4dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/cvBigImage"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/tvFilmSynopsis"
                >
                <ImageView
                    android:id="@+id/ivPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:src="@drawable/sotl"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    >

                </ImageView>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvFilmTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toBottomOf="@id/cvBigImage"
                app:layout_constraintEnd_toStartOf="@id/cvPoster"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="@string/title_f01"
                android:textStyle="bold"
                android:textSize="24dp">

            </TextView>

            <TextView
                android:id="@+id/tvFilmSynopsis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                tools:text="@string/synopsis_f01"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvFilmTitle"
                app:layout_constraintEnd_toStartOf="@id/cvPoster"
                app:layout_constraintStart_toStartOf="parent"
                >

            </TextView>

            <TextView
                android:id="@+id/tvFilmRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="@string/rating"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_marginTop="12dp"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvFilmSynopsis"
                app:layout_constraintStart_toStartOf="parent"
                >

            </TextView>

            <TextView
                android:id="@+id/tvfilmScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="@string/score_f01"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_marginTop="12dp"
                android:layout_marginStart="4dp"
                app:layout_constraintStart_toEndOf="@id/tvFilmRating"
                app:layout_constraintTop_toBottomOf="@id/tvFilmSynopsis">

            </TextView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/headercard"
                app:cardCornerRadius="16dp"
                android:layout_margin="4dp"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvFilmRating"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvFilmReview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="@string/review"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="4dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                    </TextView>

                    <TextView
                        android:id="@+id/tvFilmComment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        tools:text="@string/review_f01"
                        android:textSize="14sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="8dp"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:layout_marginBottom="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvFilmReview"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                    </TextView>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>